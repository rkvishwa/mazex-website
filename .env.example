APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id
APPWRITE_API_KEY=your_server_api_key
APPWRITE_ADMIN_LABEL=admin
APPWRITE_DB_ID=mazex_data


APPWRITE_COLLECTION_RESOURCES=resources
APPWRITE_TABLE_SPONSORS=sponsors
APPWRITE_COLLECTION_REGISTRATION_FORMS=registration_forms
APPWRITE_COLLECTION_REGISTRATION_FIELDS=registration_fields
APPWRITE_COLLECTION_REGISTRATION_SUBMISSIONS=registration_submissions
APPWRITE_COLLECTION_REGISTRATION_UNIQUE_VALUES=registration_unique_values
APPWRITE_COLLECTION_REGISTRATION_CONTACTS=registration_contacts
APPWRITE_COLLECTION_GOOGLE_SHEETS_FORM_SYNCS=google_sheets_form_syncs
APPWRITE_COLLECTION_GOOGLE_SHEETS_CONNECTIONS=google_sheets_connections


APPWRITE_BUCKET_SPONSORS=sponsor_assets
APPWRITE_BUCKET_FORM_BANNERS=form_banners
APPWRITE_BUCKET_REGISTRATION_FILES=registration_files
APPWRITE_BUCKET_EMAIL_ASSETS=email_assets
APPWRITE_MESSAGING_EMAIL_PROVIDER_ID=


# Optional override for the admin contacts broadcast action.
APPWRITE_FUNCTION_RESEND_CONTACTS_ID=registration_resend_contacts


REGISTRATION_CONFIRMATION_EMAIL_SMTP_HOST=smtp.example.com
REGISTRATION_CONFIRMATION_EMAIL_SMTP_PORT=587
REGISTRATION_CONFIRMATION_EMAIL_SMTP_SECURE=false
REGISTRATION_CONFIRMATION_EMAIL_SMTP_USER=your_smtp_username
REGISTRATION_CONFIRMATION_EMAIL_SMTP_PASS=your_smtp_password
REGISTRATION_CONFIRMATION_EMAIL_FROM=MazeX <no-reply@example.com>
REGISTRATION_CONFIRMATION_EMAIL_REPLY_TO=


GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=


# Required for admin contact messaging and Resend contact sync.
RESEND_API_KEY=

# Required for marketing broadcasts sent to registration segments.
# `RESEND_MARKETING_FROM` is preferred, but `RESEND_FROM` also works as a fallback.
RESEND_MARKETING_FROM=MazeX <broadcast@example.com>
RESEND_MARKETING_REPLY_TO=

# Optional fallback names if you prefer generic Resend vars.
RESEND_FROM=
RESEND_REPLY_TO=

# Optional custom segment names in Resend.
RESEND_SEGMENT_ALL_NAME=MazeX All Registered Users
RESEND_SEGMENT_COMPETITION_NAME=MazeX Competition Registrants
RESEND_SEGMENT_WORKSHOP_NAME=MazeX Workshop Registrants
